# 开发环境配置示例
# 复制此文件为 .env.development 并根据需要修改

# TTS API服务器地址（实时生成音频）
# 留空表示不使用TTS API，使用本地静态文件
VITE_TTS_API_URL=https://tts.zhdnpx.cn

# 静态音频文件服务器地址
# 留空表示使用本地public目录下的文件
VITE_AUDIO_BASE_URL=

# 说明：
# 1. 如果配置了 VITE_TTS_API_URL，将优先使用TTS API实时生成音频
# 2. 如果TTS API不可用或未配置，将使用 VITE_AUDIO_BASE_URL 指定的静态文件
# 3. 如果两者都未配置，将使用本地 public/audio 目录下的文件
