# 生产环境配置示例
# 复制此文件为 .env.production 并根据需要修改

# TTS API服务器地址（实时生成音频）
# 推荐：用于新增内容或小规模部署
VITE_TTS_API_URL=https://tts.zhdnpx.cn

# 静态音频文件服务器地址
# 推荐：用于常用内容或大规模部署
VITE_AUDIO_BASE_URL=https://files.zhdnpx.cn

# 部署方案选择：
#
# 方案1: 仅使用TTS API（实时生成）
# VITE_TTS_API_URL=https://tts.zhdnpx.cn
# VITE_AUDIO_BASE_URL=
#
# 方案2: 仅使用静态文件服务器
# VITE_TTS_API_URL=
# VITE_AUDIO_BASE_URL=https://files.zhdnpx.cn
#
# 方案3: 混合模式（推荐）
# VITE_TTS_API_URL=https://tts.zhdnpx.cn
# VITE_AUDIO_BASE_URL=https://files.zhdnpx.cn
# 说明：优先使用TTS API，失败时fallback到静态文件
